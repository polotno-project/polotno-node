{
  "name": "polotno-node",
  "version": "2.15.19",
  "description": "Polotno workflow from NodeJS",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "test": "npm run build && vitest run test/static/static.test.mjs",
    "test:video": "npm run build && vitest run test/video/video.test.mjs",
    "test:all": "npm run build && vitest run test/static/static.test.mjs test/video/video.test.mjs",
    "build": "rm -rf ./dist && npx vite build ./client/ --base=./ --outDir ../dist --emptyOutDir --logLevel error",
    "dev": "vite ./client.html"
  },
  "files": [
    "dist",
    "index.js",
    "index.d.ts",
    "instance.js",
    "video-parallel.js",
    "README.md"
  ],
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "devDependencies": {
    "@polotno/video-export": "^0.0.11",
    "axios": "^1.17.0",
    "dotenv": "^17.4.2",
    "fluent-ffmpeg": "^2.1.3",
    "jspdf": "^4.2.1",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "web-audio-api": "^1.5.1"
  },
  "overrides": {
    "@polotno/video-export": {
      "polotno": "$polotno",
      "mediabunny": "$mediabunny"
    }
  },
  "author": "Anton Lavrenov",
  "license": "MIT",
  "dependencies": {
    "@sparticuz/chromium": "^149.0.0",
    "mediabunny": "^1.46.0",
    "polotno": "^4.0.0-beta.49",
    "puppeteer": "25.1.0",
    "puppeteer-core": "25.1.0",
    "tmp": "^0.2.7"
  },
  "bugs": {
    "url": "https://github.com/polotno-project/polotno-node/issues"
  },
  "homepage": "https://github.com/polotno-project/polotno-node",
  "readmeFilename": "README.md",
  "repository": {
    "type": "git",
    "url": "git@github.com:polotno-project/polotno-node.git"
  }
}
